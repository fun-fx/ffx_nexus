# Copy to .env and fill in real values. .env is gitignored — never commit real keys.
#   cp .env.example .env
# Nexus auto-loads .env on startup (real environment variables take precedence).
#
# NOTE: .env is a LOCAL DEVELOPMENT / E2E convenience only. In production,
# inject these via a secret manager (K8s Secret, Vault, cloud Secrets Manager),
# and manage upstream provider keys via the encrypted credential store (Phase 2).

# --- Provider keys (set only the ones you want to test) ---
# In v0.1.0+ these are NOT used to make provider calls unless
# NEXUS_ALLOW_SHARED_KEYS=true is also set. Each end-user registers their
# own keys via the console (BYOK) — see README "Opt-in shared-key fallback".
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Key resolution mode (default: strict_byok) ---
# Override only if you need to fall back to a different policy.
# NEXUS_KEY_MODE=strict_byok
# Opt-in escape hatch: lets env/org keys act as a *fallback* in any mode.
# When false (the default), env keys are loaded but unused.
# NEXUS_ALLOW_SHARED_KEYS=false

# --- Trace persistence (optional; empty = live-only traces) ---
# NEXUS_CLICKHOUSE_URL=clickhouse://nexus:nexus@localhost:9000/nexus

# --- Rate limiting & budgets (optional; empty = in-memory single-node) ---
# Redis shares per-key RPM limits and monthly spend across gateway replicas.
# NEXUS_REDIS_URL=redis://localhost:6379/0

# --- Control plane (optional; empty = zero-dependency mode, no key auth) ---
# Postgres enables virtual keys + encrypted provider credential store.
# NEXUS_POSTGRES_URL=postgres://nexus:nexus@localhost:5433/nexus?sslmode=disable
# 32-byte key (base64 or hex) used to encrypt provider secrets at rest.
# Generate with: openssl rand -hex 32   — PERSIST IT (needed to decrypt).
# NEXUS_MASTER_KEY=

# --- Listen addresses (optional) ---
# NEXUS_GATEWAY_ADDR=:8080
# NEXUS_CONSOLE_ADDR=:8081

# --- Upstream timeout (optional) ---
# NEXUS_UPSTREAM_TIMEOUT=120s

# --- Local SLM judge (Phase 3; optional) ---
# Heuristic evals (PII, completeness) always run when ClickHouse is configured.
# The LLM-as-judge runs on a sampled fraction of traces; keep it local for
# data privacy. Enabled only when NEXUS_JUDGE_BASE_URL is set.
# NEXUS_JUDGE_BASE_URL=http://localhost:11434/v1
# NEXUS_JUDGE_MODEL=qwen2.5:7b
# NEXUS_JUDGE_API_KEY=
# NEXUS_EVAL_SAMPLE_RATE=1.0
# Concurrent eval worker goroutines (off the hot path).
# NEXUS_EVAL_WORKERS=4

# --- External Python eval service (optional; DeepEval + RAGAS sidecar) ---
# Runs out-of-band like the SLM judge (sample-gated, async). If the service is
# slow or down, evaluation degrades to the Go heuristics — the gateway hot path
# is never affected. Start it with: docker compose --profile eval up -d eval-service
# NEXUS_EVAL_SERVICE_URL=http://localhost:8200
# Comma-separated metric ids. Trace-only metrics work today; context-dependent
# ones (hallucination, ragas_faithfulness) are skipped unless contexts are sent.
# NEXUS_EVAL_SERVICE_METRICS=answer_relevancy,toxicity,bias
# NEXUS_EVAL_SERVICE_TIMEOUT=30s

# --- Quality-aware routing (Phase 4; optional, needs ClickHouse) ---
# Send requests to model "auto" to route across all registered models, or
# define named groups. Routing blends rolling eval quality, cost, and latency.
# NEXUS_ROUTE_GROUPS=fast=gpt-4o-mini,gemini-2.5-flash;smart=gpt-4o,claude-3-5-sonnet-latest
# NEXUS_ROUTE_W_QUALITY=0.6
# NEXUS_ROUTE_W_COST=0.2
# NEXUS_ROUTE_W_LATENCY=0.2
# NEXUS_ROUTE_WINDOW=1h
# NEXUS_ROUTE_REFRESH=30s

# --- Inline guardrails (optional; hot path policy checks) ---
# Synchronous checks that block a request before the upstream call or redact the
# response after it. Cheap (regex + length only); no datastores required.
# NEXUS_GUARDRAILS_ENABLED=true
# Reject prompts containing PII (email/SSN/phone/card) before any upstream call.
# NEXUS_GUARDRAILS_BLOCK_PII_INPUT=true
# Redact PII from non-streaming responses (replaced with [REDACTED]).
# NEXUS_GUARDRAILS_REDACT_PII_OUTPUT=true
# Reject prompts longer than N characters (0 = unlimited).
# NEXUS_GUARDRAILS_MAX_INPUT_CHARS=20000
# Semicolon-separated regexes; a match in the prompt rejects the request.
# NEXUS_GUARDRAILS_DENY_PATTERNS=(?i)ignore previous instructions;(?i)system prompt
# Validate JSON output when a request sets response_format (json_object/json_schema).
# Non-streaming violations are blocked with 422 schema_validation_failed.
# NEXUS_GUARDRAILS_VALIDATE_JSON_OUTPUT=true

# --- Structured-output self-correction (optional; non-streaming hot path) ---
# When the schema guardrail rejects a JSON response, retry the model with a
# correction prompt before failing. Requires VALIDATE_JSON_OUTPUT above.
# NEXUS_SELF_CORRECTION_ENABLED=true
# NEXUS_SELF_CORRECTION_MAX_RETRIES=1

# --- Route load balancing (optional; requires ClickHouse routing) ---
# Rank-weighted round-robin of the primary model among quality-qualified candidates
# in a routing alias (better models get proportionally more primary traffic).
# NEXUS_ROUTE_LOAD_BALANCE=true

# --- Semantic cache (optional; requires Redis + embeddings endpoint) ---
# Return stored completions for near-duplicate prompts without an upstream call.
# NEXUS_SEMANTIC_CACHE_ENABLED=true
# NEXUS_SEMANTIC_CACHE_TTL=24h
# NEXUS_SEMANTIC_CACHE_THRESHOLD=0.92
# NEXUS_SEMANTIC_CACHE_MAX_ENTRIES=500
# NEXUS_EMBEDDINGS_URL=http://localhost:11434/v1
# NEXUS_EMBEDDINGS_MODEL=nomic-embed-text
# NEXUS_EMBEDDINGS_API_KEY=
# Hot-path embedding budget; on timeout the cache degrades to a normal upstream call.
# NEXUS_EMBEDDINGS_TIMEOUT=5s

# --- Observability (optional) ---
# Bind a Prometheus-compatible /metrics endpoint on the gateway. Empty disables
# the scrape surface entirely (zero-dep fast path).
# NEXUS_METRICS_ADDR=:9090
# Export traces via OTLP/HTTP to a collector, Honeycomb, Tempo, etc. Both must
# be set; the endpoint alone is ignored (opt-in). Leave empty for off.
# NEXUS_OTLP_ENABLED=false
# NEXUS_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# --- Failover alert sinks (optional; V4) ---
# Each is independently opt-in; an empty URL means "no goroutines, no
# resolver, no DNS". POSTed with a small payload — see
# internal/router/notifier.go for the FailoverEvent schema.
# NEXUS_FAILOVER_WEBHOOK=https://alerts.example.com/nexus
# NEXUS_FAILOVER_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...
# Optional cooldown coalesces back-to-back alerts onto the same sink so a
# flapping primary doesn't melt the alert inbox. 0 = disabled (one per event).
# NEXUS_FAILOVER_ALERT_COOLDOWN=0

# --- Metabase BI adapter (mirror of the V3 OTLP toggle) ------------------------
# Empty NEXUS_METABASE_URL = adapter fully off (no goroutines, no DNS, no boot
# network calls). When set, Nexus runs a one-shot, idempotent bootstrap on
# startup: poll /api/health, log in, register ClickHouse + Postgres as
# datasources, and (optionally) seed any *.json collection exports under
# NEXUS_METABASE_SEED_DIR. Hot-path traces still flow through the existing CH
# / OTLP recorders; Metabase is pull-only (standard SQL over the ClickHouse
# HTTP endpoint and Postgres JDBC), so there is no extra data movement.
#
# Locally:  docker compose --profile bi up -d
# Cluster:   set NEXUS_METABASE_URL to a Metabase service in your cluster
#            (or any managed/hosted Metabase URL).
# NEXUS_METABASE_URL=http://metabase:3000
# NEXUS_METABASE_USER=admin@nexus.local
# NEXUS_METABASE_PASSWORD=change-me-now
# NEXUS_METABASE_CLICKHOUSE_URL=http://clickhouse:8123?database=nexus
# NEXUS_METABASE_POSTGRES_URL=postgres://nexus:nexus@postgres:5432/nexus
# NEXUS_METABASE_SEED_DIR=./deploy/observability/metabase/seed
# NEXUS_METABASE_HEALTH_TIMEOUT=90s
# NEXUS_METABASE_REQUEST_TIMEOUT=10s

# --- V5 high-concurrency tuning -------------------------------------------
# Per-vkey in-flight cap on a single replica. Bounds one noisy virtual
# key's footprint at the upstream provider queue. Excess returns
# 429 concurrency_exceeded with Retry-After: 1. 0 = disabled (RPM-only).
# Recommended: 16–32 for shared upstream pools.
# NEXUS_MAX_CONCURRENT_PER_KEY=0
# GOMEMLIMIT / GOGC live at the pod level (Helm values.yaml
# config.runtime.{gomemlimit,gogc}; ConfigMap → env vars). Setting to ""
# leaves both unset, which means "no advisory".
