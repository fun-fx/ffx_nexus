# Observability stack — one config file per tool. The Nexus compose
# `observability` profile mounts this directory read-only.
# Don't put secrets here; everything baked here is a published Grafana/Prom
# default. Local-only credentials live in `.env` (git-ignored).
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer

# Provisioned dashboards pick up dashboards.json from /var/lib/grafana/dashboards.
GF_PATHS_PROVISIONING=/etc/grafana/provisioning
