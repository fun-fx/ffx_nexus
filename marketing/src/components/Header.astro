---
const links = [
  { href: "/#features", label: "Features" },
  { href: "/#metrics", label: "Why Nexus" },
  { href: "/enterprise", label: "Enterprise" },
  { href: "/pricing", label: "Pricing" },
  { href: "/docs", label: "Docs" },
];

const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-ink-800/60 bg-ink-950/70 backdrop-blur-md">
  <div class="container-wide flex h-14 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold text-white">
      <svg
        width="22"
        height="22"
        viewBox="0 0 22 22"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path d="M11 1L21 6.5V15.5L11 21L1 15.5V6.5L11 1Z" stroke="url(#g)" stroke-width="1.5" fill="rgba(82,82,255,0.10)" />
        <path d="M7.5 8.5L11 6.5L14.5 8.5V13.5L11 15.5L7.5 13.5V8.5Z" fill="url(#g)" />
        <defs>
          <linearGradient id="g" x1="1" y1="1" x2="21" y2="21">
            <stop offset="0%" stop-color="#a8a8ff" />
            <stop offset="100%" stop-color="#5252ff" />
          </linearGradient>
        </defs>
      </svg>
      <span>Nexus</span>
      <span class="ml-1 hidden rounded border border-ink-700 px-1.5 py-0.5 text-[10px] font-mono uppercase tracking-wider text-ink-300 sm:inline">v0.3.5</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "btn-ghost",
            (path === l.href || (l.href !== "/" && path.startsWith(l.href))) && "text-white",
          ]}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="https://github.com/fun-fx/ffx_nexus" class="btn-ghost hidden sm:inline-flex" aria-label="GitHub">
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
        </svg>
        <span class="ml-1.5">GitHub</span>
      </a>
      <a href="/pricing" class="btn-primary">Get started</a>
    </div>
  </div>
</header>
