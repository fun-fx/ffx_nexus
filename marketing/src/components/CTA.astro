---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  primary?: { href: string; label: string };
  secondary?: { href: string; label: string };
}

const { eyebrow, title, description, primary, secondary } = Astro.props;
---

<section class="container-wide py-24 sm:py-32">
  <div class="panel relative overflow-hidden p-10 text-center sm:p-16">
    <div class="absolute inset-0 -z-10 bg-card-glow"></div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2 class="mt-4 text-balance text-4xl font-semibold sm:text-5xl">
      <span class="gradient-text">{title}</span>
    </h2>
    {description && (
      <p class="mx-auto mt-4 max-w-2xl text-pretty text-lg text-ink-200">{description}</p>
    )}
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      {primary && <a href={primary.href} class="btn-primary px-5 py-2.5 text-base">{primary.label}</a>}
      {secondary && <a href={secondary.href} class="btn-secondary px-5 py-2.5 text-base">{secondary.label}</a>}
    </div>
  </div>
</section>
