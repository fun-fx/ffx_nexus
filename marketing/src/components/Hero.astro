---
import CodeBlock from "./CodeBlock.astro";
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-hero-grid bg-grid-32 opacity-30 [mask-image:radial-gradient(ellipse_60%_60%_at_50%_30%,black,transparent)]"></div>
  <div class="absolute inset-0 -z-10 bg-hero-glow"></div>

  <div class="container-wide pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow animate-fade-up">Open-Source AI Gateway</p>
      <h1 class="mt-5 text-balance text-5xl font-semibold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
        <span class="gradient-text">One endpoint.</span><br />
        <span class="gradient-text">Every model.</span><br />
        <span class="text-ink-100">Total control.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-ink-200">
        Nexus is a drop-in replacement for the OpenAI/Anthropic/Gemini API. BYOK,
        virtual keys, guardrails, semantic caching, and observability — without
        giving up your provider accounts.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/pricing" class="btn-primary px-5 py-2.5 text-base">
          Get started — free
        </a>
        <a href="https://github.com/fun-fx/ffx_nexus" class="btn-secondary px-5 py-2.5 text-base">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
          </svg>
          Star on GitHub
        </a>
      </div>

      <p class="mt-5 text-xs text-ink-400">
        Apache 2.0 · self-hostable · MIT-licensed UI · production-grade observability
      </p>
    </div>

    <div class="mx-auto mt-16 max-w-4xl">
      <CodeBlock
        language="python"
        code={`from openai import OpenAI

# Same SDK, drop in Nexus as the base URL.
client = OpenAI(
    base_url="https://nexus.ffx.ai/v1",
    api_key="nxs_live_...",
)

resp = client.chat.completions.create(
    model="gemini-2.5-flash",
    messages=[{"role": "user", "content": "Hello, Nexus."}],
)`}
      />
    </div>
  </div>
</section>
