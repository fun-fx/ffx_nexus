---
const steps = [
  {
    n: "01",
    title: "Self-host or use the cloud",
    body: "Run our Helm chart in your own Kubernetes, or sign up for a managed tenant on nexus.ffx.ai.",
  },
  {
    n: "02",
    title: "Plug in your provider keys",
    body: "Per-user BYOK or org-level platform credentials. Encrypted at rest with KMS-managed keys.",
  },
  {
    n: "03",
    title: "Mint virtual keys for your apps",
    body: "Each app or team gets a virtual key with its own budget, allowed models, and rate limit.",
  },
  {
    n: "04",
    title: "Watch the dashboard",
    body: "Traces, costs, eval scores, and quality — by user, team, model, or virtual key.",
  },
];
---

<section id="how" class="container-wide py-24 sm:py-32">
  <div class="mx-auto max-w-2xl text-center">
    <p class="eyebrow">How it works</p>
    <h2 class="mt-4 text-balance text-4xl font-semibold sm:text-5xl">
      From <code class="text-brand-200">pip install</code> to <code class="text-brand-200">$1M/mo</code> spend — same code.
    </h2>
  </div>

  <ol class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {steps.map((s) => (
      <li class="panel p-6">
        <div class="font-mono text-xs text-brand-300">{s.n}</div>
        <h3 class="mt-3 text-lg font-semibold text-white">{s.title}</h3>
        <p class="mt-2 text-sm text-ink-300">{s.body}</p>
      </li>
    ))}
  </ol>
</section>
