---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout title="404 — page not found" description="The page you were looking for doesn't exist.">
  <Header />
  <main>
    <section class="container-wide py-32">
      <div class="mx-auto max-w-xl text-center">
        <p class="eyebrow">404</p>
        <h1 class="mt-4 text-balance text-5xl font-semibold sm:text-6xl">
          <span class="gradient-text">Off the map.</span>
        </h1>
        <p class="mt-4 text-lg text-ink-200">
          The page you're looking for doesn't exist — but the home page does.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/" class="btn-primary px-5 py-2.5">Back to home</a>
          <a href="/docs" class="btn-secondary px-5 py-2.5">Read the docs</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
