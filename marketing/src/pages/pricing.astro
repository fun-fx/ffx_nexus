---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CTA from "@components/CTA.astro";

const tiers = [
  {
    name: "OSS",
    price: "Free",
    period: "forever",
    blurb: "Self-host, BYOK, virtual keys, guardrails, observability. The whole core.",
    features: [
      "Apache 2.0 license",
      "BYOK for OpenAI / Anthropic / Gemini / +",
      "Virtual keys with budgets and rate limits",
      "Guardrails + semantic cache + eval",
      "OpenTelemetry trace export",
      "Community Discord support",
    ],
    cta: { href: "https://github.com/fun-fx/ffx_nexus", label: "View on GitHub" },
    highlighted: false,
  },
  {
    name: "Cloud",
    price: "$0.05",
    period: "per 1k traced requests",
    blurb: "Managed multi-tenant Nexus on nexus.ffx.ai. No infra to run.",
    features: [
      "Everything in OSS",
      "Hosted in EU/US/AP regions",
      "99.9% uptime SLA",
      "Daily backups + 7-day retention",
      "Email support, < 24h response",
      "Free tier: 100k req/mo",
    ],
    cta: { href: "mailto:hello@ffx.ai?subject=Cloud%20signup", label: "Sign up for cloud" },
    highlighted: true,
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "annual",
    blurb: "Self-hosted in your VPC. SSO/SAML, multi-tenant, audit, SLA.",
    features: [
      "Everything in Cloud",
      "SSO / SAML / OIDC (Okta, Azure AD, Keycloak)",
      "Multi-tenant realms + KMS-managed keys",
      "SOC 2 Type II (in progress)",
      "Dedicated Slack + 99.9% SLA",
      "Air-gapped / on-prem deployment",
    ],
    cta: { href: "mailto:enterprise@ffx.ai", label: "Contact sales" },
    highlighted: false,
  },
];
---

<BaseLayout
  title="Pricing"
  description="Free open-source. Cloud at $0.05 per 1k traced requests. Enterprise for SSO, multi-tenant, and on-prem."
>
  <Header />
  <main>
    <section class="container-wide pt-20 pb-12 sm:pt-28">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow">Pricing</p>
        <h1 class="mt-5 text-balance text-5xl font-semibold sm:text-6xl">
          <span class="gradient-text">Free for self-hosters.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-200">
          OSS for the core, cloud for managed, enterprise for SSO + multi-tenant + audit.
        </p>
      </div>
    </section>

    <section class="container-wide pb-16">
      <div class="grid gap-4 lg:grid-cols-3">
        {tiers.map((t) => (
          <div class:list={[
            "panel relative p-8 transition-colors",
            t.highlighted && "border-brand-500/50 bg-ink-900/70",
          ]}>
            {t.highlighted && (
              <span class="absolute -top-3 right-6 rounded-full bg-brand-500 px-3 py-1 text-xs font-medium text-white">
                Most popular
              </span>
            )}
            <h3 class="text-xl font-semibold text-white">{t.name}</h3>
            <div class="mt-4 flex items-baseline gap-1.5">
              <span class="text-4xl font-semibold tracking-tight text-white">{t.price}</span>
              <span class="text-sm text-ink-300">/ {t.period}</span>
            </div>
            <p class="mt-3 text-sm text-ink-200">{t.blurb}</p>
            <ul class="mt-6 space-y-2.5 text-sm">
              {t.features.map((f) => (
                <li class="flex items-start gap-2.5 text-ink-200">
                  <svg viewBox="0 0 20 20" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-300" fill="currentColor"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 0 1 1.4-1.4L8.5 12l6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" /></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href={t.cta.href}
              class:list={[
                "mt-8 inline-flex w-full justify-center px-4 py-2.5 text-sm font-medium",
                t.highlighted ? "btn-primary" : "btn-secondary",
              ]}
            >
              {t.cta.label}
            </a>
          </div>
        ))}
      </div>
    </section>

    <section class="container-narrow pb-24">
      <h2 class="text-2xl font-semibold text-white">Frequently asked</h2>
      <dl class="mt-6 grid gap-x-12 gap-y-4 sm:grid-cols-2">
        <div>
          <dt class="font-medium text-white">How is "traced request" counted?</dt>
          <dd class="mt-1 text-sm text-ink-300">Each request that emits an OpenTelemetry span to our managed ClickHouse. Cached responses still count.</dd>
        </div>
        <div>
          <dt class="font-medium text-white">Can I switch tiers later?</dt>
          <dd class="mt-1 text-sm text-ink-300">Yes. You can export your data and migrate from OSS → Cloud → Enterprise at any time.</dd>
        </div>
        <div>
          <dt class="font-medium text-white">What about LLM provider costs?</dt>
          <dd class="mt-1 text-sm text-ink-300">Nexus never charges for LLM tokens. You pay your provider directly; Nexus only charges for the gateway layer.</dd>
        </div>
        <div>
          <dt class="font-medium text-white">Do you offer non-profit / academic pricing?</dt>
          <dd class="mt-1 text-sm text-ink-300">Yes — Cloud is free for verified academic and non-profit institutions. Email us.</dd>
        </div>
      </dl>
    </section>

    <CTA
      eyebrow="Get started"
      title="Self-host in 5 minutes — or sign up for cloud."
      primary={{ href: "https://github.com/fun-fx/ffx_nexus", label: "Get the OSS chart" }}
      secondary={{ href: "mailto:hello@ffx.ai?subject=Cloud%20signup", label: "Talk to sales" }}
    />
  </main>
  <Footer />
</BaseLayout>
